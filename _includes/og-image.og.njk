<style>
.root {
  width: 1200px;
  height: 630px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  background-color: #f4f7f6;
  color: #34495e;
  padding: 60px 80px;
  box-sizing: border-box;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-grow: 1;
  width: 100%;
  max-height: 420px;
  overflow: hidden;
}

.title {
  font-family: "Nunito", "Helvetica Neue", Arial, sans-serif;
  font-size: 72px;
  font-weight: 800;
  text-align: center;
  line-height: 1.1;
  margin: 0;
  max-width: 1040px;
  color: #2d3e50;
  letter-spacing: -0.02em;
}

.subtitle {
  margin-top: 24px;
  font-family: "Nunito", "Helvetica Neue", Arial, sans-serif;
  font-size: 28px;
  color: #7f8c8d;
  text-align: center;
  max-width: 900px;
  line-height: 1.4;
}

.footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 100%;
  border-top: 1px solid #dde4eb;
  padding-top: 30px;
  margin-top: auto;
}

.logo-container {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.logo-image {
  width: 52px;
  height: 52px;
  margin-right: 16px;
}

.logo-text {
  font-family: "Nunito", "Helvetica Neue", Arial, sans-serif;
  font-size: 36px;
  font-weight: 800;
  color: #2d3e50;
  letter-spacing: -0.01em;
  display: flex;
  flex-direction: row;
}

.brand-dot {
  color: #3498db;
}
</style>

<div class="root">
  <div class="content">
    <div class="title">{{ title | default("Daily Pick") }}</div>
    {% if subtitle %}
      <div class="subtitle">{{ subtitle | truncate(160) }}</div>
    {% endif %}
  </div>
  
  <div class="footer">
    <div class="logo-container">
      <div style="width: 52px; height: 52px; background-color: #3498db; border-radius: 12px; margin-right: 16px; display: flex; align-items: center; justify-content: center;">
        <span style="color: white; font-size: 32px; font-weight: 800;">DP</span>
      </div>
      <div class="logo-text">Daily Pick<span class="brand-dot">.</span>dev</div>
    </div>
  </div>
</div>
