<section class="related-games-section glass-card">
    <div class="section-header">
        <p class="hero-eyebrow">More World Cup Fun</p>
        <h2 class="section-title">Explore FIFA 2026 Games & Tools</h2>
    </div>
    <ul class="related-game-grid" role="list">
        {% for app in apps %}
            {% if app.category == 'fifa-2026' and app.path != page.url %}
                <li class="related-game-item">
                    <a class="related-game-card" href="{{ app.path }}">
                        <span aria-hidden="true" class="related-game-icon">{{ app.emoji }}</span>
                        <div class="related-game-content">
                            <span class="related-game-title">{{ app.name }}</span>
                            <span class="related-game-desc">{{ app.description }}</span>
                        </div>
                    </a>
                </li>
            {% endif %}
        {% endfor %}
    </ul>
</section>

<style>
.related-games-section {
    margin: 2.5rem auto;
    padding: 1.75rem 1.25rem;
    max-width: 860px;
    width: 90%;
    text-align: center;
}

.related-games-section .section-header {
    margin-bottom: 1.5rem;
}

.related-games-section .hero-eyebrow {
    display: inline-block;
    margin: 0;
    color: var(--brand-subtle-text);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
}

.related-games-section .section-title {
    font-size: clamp(1.6rem, 2.1vw, 1.9rem);
    font-weight: 800;
    margin: 0.5rem auto 0;
    color: var(--brand-heading, #10203f);
}

.related-game-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
}

.related-game-card {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.75rem;
    background-color: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: var(--radius-lg, 16px);
    box-shadow: var(--brand-card-shadow, 0 10px 20px rgba(0,0,0,0.05));
    text-decoration: none;
    color: var(--brand-text);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.related-game-card:hover,
.related-game-card:focus-visible {
    transform: translateY(-4px) scale(1.005);
    border-color: var(--brand-accent, #3498db);
    box-shadow: var(--brand-hover-shadow, 0 18px 35px rgba(0,0,0,0.12));
}

.related-game-card:focus-visible {
    outline: none;
    box-shadow: var(--brand-focus-ring, 0 0 0 3px rgba(52, 152, 219, 0.25));
}

.related-game-icon {
    font-size: 2.2rem;
    flex-shrink: 0;
    line-height: 1;
}

.related-game-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.related-game-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--brand-heading, #10203f);
}

.related-game-desc {
    font-size: 0.95rem;
    color: var(--brand-subtle-text, #666);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

@media (max-width: 600px) {
    .related-games-section {
        padding: 2rem 1.5rem;
    }
    .related-game-card {
        padding: 1.2rem;
    }
}
</style>
