<!DOCTYPE html>
<html lang="{{ lang or 'en' }}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    {% set pageTitle = title or metadata.siteTitle %}
    {% set pageDescription = description or metadata.siteDescription %}
    {% set pageKeywords = keywords %}
    {% set robotsMeta = robots or "index,follow" %}
    {% set canonicalUrl = canonical or (metadata.url + page.url) %}

    {% setAsync "generatedOgImage" -%}
        {% ogImage "./_includes/og-image.og.njk", { title: pageTitle, subtitle: pageDescription } %}
    {%- endsetAsync %}

    {% set ogImagePath = generatedOgImage or ogImage or metadata.defaultOgImage or '/assets/og-image-main.png' %}
    {% set twitterImagePath = twitterImage or ogImagePath or metadata.defaultTwitterImage %}
    {% set ogImageAbsolute = ogImagePath %}
    {% if ogImageAbsolute and not ogImageAbsolute.startsWith("http") %}
        {% set ogImageAbsolute = metadata.url + ogImageAbsolute %}
    {% endif %}
    {% set twitterImageAbsolute = twitterImagePath %}
    {% if twitterImageAbsolute and not twitterImageAbsolute.startsWith("http") %}
        {% set twitterImageAbsolute = metadata.url + twitterImageAbsolute %}
    {% endif %}
    {% set ogImageAltText = ogImageAlt or pageTitle %}
    {% set twitterImageAltText = twitterImageAlt or ogImageAltText %}

    <!-- SEO -->
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    {% if pageKeywords %}<meta name="keywords" content="{{ pageKeywords }}" />{% endif %}
    <meta name="author" content="{{ author or metadata.authorName }}" />
    <meta name="robots" content="{{ robotsMeta }}" />

    <!-- Open Graph -->
    <meta property="og:type" content="{{ ogType or 'website' }}" />
    <meta property="og:url" content="{{ canonicalUrl }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    {% if ogImageAbsolute %}<meta property="og:image" content="{{ ogImageAbsolute }}" />{% endif %}
    <meta property="og:site_name" content="{{ metadata.siteTitle }}" />
    {% if ogLocale %}<meta property="og:locale" content="{{ ogLocale }}" />{% endif %}
    {% if ogImageAbsolute and ogImageAltText %}<meta property="og:image:alt" content="{{ ogImageAltText }}" />{% endif %}

    <!-- Twitter -->
    <meta name="twitter:card" content="{{ twitterCard or 'summary_large_image' }}" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />
    {% if twitterHandle %}<meta name="twitter:site" content="{{ twitterHandle }}" />{% endif %}
    {% if twitterCreator %}<meta name="twitter:creator" content="{{ twitterCreator }}" />{% endif %}
    {% if twitterImageAbsolute %}<meta name="twitter:image" content="{{ twitterImageAbsolute }}" />{% endif %}
    {% if twitterImageAbsolute and twitterImageAltText %}<meta name="twitter:image:alt" content="{{ twitterImageAltText }}" />{% endif %}

    <link rel="canonical" href="{{ canonicalUrl }}" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "name": "{{ pageTitle }}",
          "description": "{{ pageDescription }}",
          "url": "{{ canonicalUrl }}",
          "author": { "@id": "{{ metadata.url }}/#organization" },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "{{ ogImageAbsolute }}"
          }
        },
        {
          "@type": "Organization",
          "@id": "{{ metadata.url }}/#organization",
          "name": "{{ metadata.authorName or metadata.siteTitle }}",
          "url": "{{ metadata.url }}",
          "logo": "{{ metadata.url }}/assets/favicon/android-chrome-512x512.png"
        }
      ]
    }
    </script>

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png" />
    <link rel="manifest" href="/assets/favicon/site.webmanifest" />
    <link rel="shortcut icon" href="/assets/favicon/favicon.ico" />
    <meta name="msapplication-TileColor" content="#2d89ef" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    {% if isApp %}
    <!-- Google Fonts (app pages) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" />
    {% endif %}

    <!-- Core styles -->
    {% if not isApp %}
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
    <link rel="stylesheet" href="/assets/css/theme.css" />
    {# home.css is needed on the homepage, blog index, and suite pages #}
    {% if page.url == '/' or (page.url and (page.url == '/blog/' or page.url.startsWith('/blog/page') or page.url == '/agile/' or page.url == '/randomizers/' or page.url == '/standups/' or page.url == '/games/' or page.url == '/lottery/' or page.url == '/food/' or page.url == '/apps/')) %}
        <link rel="stylesheet" href="/assets/css/home.css" />
    {% endif %}
    {% else %}
    <link rel="stylesheet" href="/assets/css/theme.css" />
    {% endif %}

    <link rel="stylesheet" href="/assets/css/pwa-install.css" />
    <link rel="stylesheet" href="/assets/css/glass.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/seo-card.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/feedback-popup.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/presentation-mode.css" media="print" onload="this.media='all'" />
    <script>
      (function () {
        var deferredStyles = document.querySelectorAll('link[rel="stylesheet"][media="print"]');
        if (!deferredStyles.length) return;
        function enableDeferredStyles() {
          deferredStyles.forEach(function (link) {
            if (link.media !== 'all') link.media = 'all';
          });
        }
        if (document.readyState !== 'loading') {
          enableDeferredStyles();
        } else {
          window.addEventListener('DOMContentLoaded', enableDeferredStyles, { once: true });
          window.addEventListener('load', enableDeferredStyles, { once: true });
          window.addEventListener('pageshow', enableDeferredStyles);
        }
      })();
    </script>

    {% if isApp %}
    <link rel="stylesheet" href="/assets/css/standup-panel.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/local-brand-studio.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/embed.css" media="print" onload="this.media='all'" />
    {% if appStyles %}{{ appStyles | safe }}{% endif %}
    {% endif %}

    <!-- Scripts -->
    <script defer src="/assets/js/brand-theme-engine.js"></script>
    <script defer src="/assets/js/brand-config.js"></script>
    {% if isApp %}
    {% if localBrandConfig and not hideLocalBrandStudio %}
    <script>
      (function () {
        if (new URLSearchParams(window.location.search).has('overlay')) return;
        var s = document.createElement('script');
        s.defer = true;
        s.src = "{{ localBrandConfig }}";
        document.head.appendChild(s);
      })();
    </script>
    <script>
      (function () {
        if (new URLSearchParams(window.location.search).has('overlay')) return;
        var s = document.createElement('script');
        s.defer = true;
        s.src = '/assets/js/local-brand-studio.js';
        document.head.appendChild(s);
      })();
    </script>
    {% endif %}
    <script defer src="/assets/js/embed.js"></script>
    <script>
      (function () {
        if (new URLSearchParams(window.location.search).has('overlay')) return;
        window.dpBreadcrumb = window.dpBreadcrumb || {};
        window.dpBreadcrumb.apps = {{ apps | dump | safe }};
        window.dpBreadcrumb.baseUrl = window.location.hostname === 'localhost' ? window.location.origin : 'https://dailypick.dev';
        window.dpBreadcrumb.categoryPages = {
          standup: { name: 'Stand-up Games', url: window.dpBreadcrumb.baseUrl + '/standups/' },
          randomizer: { name: 'Random Pickers & Decision Tools', url: window.dpBreadcrumb.baseUrl + '/randomizers/' },
          agile: { name: 'Agile Planning Tools', url: window.dpBreadcrumb.baseUrl + '/agile/' },
          games: { name: 'Games & Group Activities', url: window.dpBreadcrumb.baseUrl + '/games/' },
          lottery: { name: 'Lottery Hub', url: window.dpBreadcrumb.baseUrl + '/lottery/' },
          food: { name: 'Food Wheels', url: window.dpBreadcrumb.baseUrl + '/food/' }
        };
        window.dpBreadcrumb.homeUrl = window.dpBreadcrumb.baseUrl + '/';
        window.dpBreadcrumb.getAppCategoryMap = function () {
          var map = {};
          (window.dpBreadcrumb.apps || []).forEach(function (app) {
            map[app.path] = app.category;
          });
          return map;
        };
        window.dpBreadcrumb.buildCategoryKey = function (path) {
          var normalized = path.replace(/\/$/, '');
          var map = window.dpBreadcrumb.getAppCategoryMap();
          return map[path] || map[path + '/'] || map[normalized] || map[normalized + '/'];
        };
        window.dpBreadcrumb.getAppByPath = function (path) {
          var normalized = path.replace(/\/$/, '');
          var apps = window.dpBreadcrumb.apps || [];
          for (var i = 0; i < apps.length; i += 1) {
            var appPath = (apps[i].path || '').replace(/\/$/, '');
            if (
              apps[i].path === path ||
              appPath === normalized ||
              appPath === normalized + '/' ||
              normalized.indexOf(appPath + '/') === 0
            ) {
              return apps[i];
            }
          }
          return null;
        };
        window.dpBreadcrumb.buildPageTitle = function () {
          var pageHeading = document.querySelector('main h1')?.textContent?.trim();
          return (pageHeading || document.title || 'Tool').replace(/\s*–.*$/, '').trim();
        };

        })();
    </script>

    {% set breadcrumbTitle = (title.split('–')[0] if title else 'Tool') | trim %}
    {% set appCategoryInfo = null %}
    {% if isApp %}
      {% set normalizedPageUrl = page.url %}
      {% for app in apps %}
        {% set normalizedAppPath = app.path %}
        {% if app.path == page.url or normalizedAppPath == normalizedPageUrl %}
          {% set appCategoryInfo = app.category %}
        {% endif %}
      {% endfor %}
      {% if not appCategoryInfo %}
         {% set appCategoryInfo = page.url.split('/')[1] %}
      {% endif %}
    {% else %}
        {% set appCategoryInfo = page.url.split('/')[1] %}
    {% endif %}

    {% set categoryPages = {
      'standups': { 'name': 'Stand-up Games', 'url': metadata.url + '/standups/' },
      'standup': { 'name': 'Stand-up Games', 'url': metadata.url + '/standups/' },
      'randomizers': { 'name': 'Random Pickers & Decision Tools', 'url': metadata.url + '/randomizers/' },
      'randomizer': { 'name': 'Random Pickers & Decision Tools', 'url': metadata.url + '/randomizers/' },
      'agile': { 'name': 'Agile Planning Tools', 'url': metadata.url + '/agile/' },
      'games': { 'name': 'Games & Group Activities', 'url': metadata.url + '/games/' },
      'lottery': { 'name': 'Lottery Hub', 'url': metadata.url + '/lottery/' },
      'food': { 'name': 'Food Wheels', 'url': metadata.url + '/food/' }
    } %}
    {% set catMatched = categoryPages[appCategoryInfo] %}

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {
            "@type": "WebPage",
            "@id": "{{ metadata.url }}/",
            "name": "Home"
          }
        }
        {% if catMatched %}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ catMatched.name | dump | safe }},
          "item": {
            "@type": "WebPage",
            "@id": {{ catMatched.url | dump | safe }},
            "name": {{ catMatched.name | dump | safe }}
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ breadcrumbTitle | dump | safe }},
          "item": {
            "@type": "WebPage",
            "@id": {{ canonicalUrl | dump | safe }},
            "name": {{ breadcrumbTitle | dump | safe }}
          }
        }
        {% else %}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ breadcrumbTitle | dump | safe }},
          "item": {
            "@type": "WebPage",
            "@id": {{ canonicalUrl | dump | safe }},
            "name": {{ breadcrumbTitle | dump | safe }}
          }
        }
        {% endif %}
      ]
    }
    </script>
    {% endif %}

    <!-- Google Analytics -->
    <script data-gtag data-gtag-src="https://www.googletagmanager.com/gtag/js?id=G-N83YF635W2"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
    </script>

    {% if headExtra %}{{ headExtra | safe }}{% endif %}

    <!-- Detect PWA standalone early to avoid FOUC -->
    <script>
      (function () {
        function setStandaloneClass() {
          var standalone =
            window.matchMedia('(display-mode: standalone)').matches ||
            (navigator.standalone === true) ||
            new URLSearchParams(window.location.search).has('pwa');
          if (standalone) document.documentElement.classList.add('pwa-standalone');
        }
        setStandaloneClass();
        window.addEventListener('pageshow', setStandaloneClass);
      })();
    </script>
</head>
<body>
    {% include "bg-orbs.html" %}
    {% include "header.html" %}

    {% if isApp %}
    <!-- Visible breadcrumb for app pages (keeps in sync with JSON-LD) -->
    <nav aria-label="Breadcrumb" class="visible-breadcrumb" id="visible-breadcrumb" hidden>
        <ol>
            <li><a href="/">Home</a></li>
            <li id="breadcrumb-category"></li>
            <li id="breadcrumb-current"></li>
        </ol>
    </nav>
    <script>
    (function () {
      if (new URLSearchParams(window.location.search).has('overlay')) return;
      var app = window.dpBreadcrumb.getAppByPath(window.location.pathname);
      var categoryPages = window.dpBreadcrumb.categoryPages;
      var pageTitle = document.querySelector('main h1')?.textContent?.trim() || document.title.split('–')[0] || '';

      var nav = document.getElementById('visible-breadcrumb');
      var catEl = document.getElementById('breadcrumb-category');
      var curEl = document.getElementById('breadcrumb-current');

      if (!nav || !catEl || !curEl) return;

      if (app && categoryPages[app.category]) {
        catEl.innerHTML = '<a href="' + categoryPages[app.category].url + '">' + categoryPages[app.category].name + '</a>';
        curEl.textContent = pageTitle.trim();
      } else {
        // no category: collapse the middle item and show only Home → Current
        catEl.remove();
        curEl.textContent = pageTitle.trim();
      }

      nav.hidden = false;
    })();
    </script>
    <style>
    .visible-breadcrumb{
      font-size:0.9rem;
      margin:0.5rem auto;
      max-width:1200px;
      padding:0 1rem;
      text-align:center;
    }
    .visible-breadcrumb ol{
      list-style:none;
      padding:0;
      margin:0;
      display:flex;
      gap:.5rem;
      align-items:center;
      justify-content:center;
      flex-wrap:wrap;
    }
    .visible-breadcrumb li{white-space:nowrap}
    .visible-breadcrumb a{color:inherit;text-decoration:underline}
    .visible-breadcrumb li+li:before{content:'›';margin:0 0.4rem;color:#888}
    </style>
    {% endif %}

    {% if isApp %}
    {{ content | safe }}

    <section class="similar-apps-section glass-card" id="similarAppsSection">
        <h2>Similar Apps</h2>
        <p>Discover more tools and games in the same category.</p>
        <div class="similar-apps-grid" id="similarAppsGrid">
            <p class="similar-apps-loading" id="similarAppsLoading">Loading similar apps…</p>
        </div>
    </section>
    <script>
    (function () {
      if (new URLSearchParams(window.location.search).has('overlay')) return;
      var apps = window.dpBreadcrumb && window.dpBreadcrumb.apps;
      if (!apps || !apps.length) return;

      var currentPath = window.location.pathname.replace(/\/$/, '') + '/';
      var currentApp = apps.find(function (a) { return a.path === currentPath; });
      if (!currentApp) return;

      var categoryPages = window.dpBreadcrumb.categoryPages || {};
      var categoryInfo = categoryPages[currentApp.category];
      var categoryName = categoryInfo ? categoryInfo.name : '';
      var categoryUrl = categoryInfo ? categoryInfo.url : null;

      var similar = apps.filter(function (a) {
        return a.category === currentApp.category && a.path !== currentApp.path && a.footerGroup;
      }).slice(0, 6);

      var section = document.getElementById('similarAppsSection');
      var grid = document.getElementById('similarAppsGrid');
      var loading = document.getElementById('similarAppsLoading');
      if (!section || !grid) return;

      if (loading) loading.remove();

      if (!similar.length) {
        section.hidden = true;
        return;
      }

      if (categoryName) {
        var heading = section.querySelector('h2');
        if (heading) heading.textContent = 'More ' + categoryName;
      }

      var allHtml = '';
      similar.forEach(function (app) {
        allHtml += '<a href="' + app.path + '" class="similar-app-card">' +
          '<span class="similar-app-emoji">' + (app.emoji || '🎲') + '</span>' +
          '<span class="similar-app-name">' + app.name + '</span>' +
          '<span class="similar-app-desc">' + app.description + '</span>' +
          '</a>';
      });

      if (categoryUrl && similar.length >= 3) {
        allHtml += '<a href="' + categoryUrl + '" class="similar-app-card similar-app-card--all">' +
          '<span class="similar-app-emoji">➡️</span>' +
          '<span class="similar-app-name">View All ' + categoryName + '</span>' +
          '<span class="similar-app-desc">Browse the full collection</span>' +
          '</a>';
      }

      grid.innerHTML = allHtml;

      var seoSection = document.querySelector('.seo-content-area');
      if (seoSection && seoSection.parentNode) {
        seoSection.parentNode.insertBefore(section, seoSection);
      }
    })();
    </script>

    {% if not hideEmbed %}
    <section class="embed-section glass-card" id="embedSection">
        <h2>Embed this page</h2>
        <p>Share this page on your own site by embedding it in an iframe. Copy the HTML below and paste it into any page.</p>
        <div class="embed-controls">
            <textarea id="embedCode" readonly aria-label="Embed code"></textarea>
            <button id="copyEmbedBtn" type="button">Copy embed code</button>
        </div>
        <p class="embed-note">This iframe loads only the embedded game experience without the site header, footer, or SEO content.</p>
    </section>
    {% endif %}
    {% else %}
    <main>
        {{ content | safe }}
    </main>
    {% endif %}

    {% include "footer.html" %}

    {% include "cookie-consent.html" %}
    {% include "pwa-install.html" %}
    {% include "pwa-nav.html" %}
    {% include "pwa-search.html" %}
    {% include "feedback-popup.html" %}

    <script src="/assets/js/cookie-consent.js" defer></script>
    <script src="/assets/js/feature-tracking.js" defer></script>
    <script src="/assets/js/presentation-mode.js" defer></script>
    <script src="/assets/js/pwa-install.js" defer></script>
    <script src="/assets/js/feedback-popup.js" defer></script>
</body>
</html>
